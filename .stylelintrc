# =============================================================
# Stylelint CSS/Less 检查配置文件
# =============================================================
#
# 【泛化描述】.stylelintrc 是 Stylelint 的配置文件，
#             Stylelint 是一个 CSS/Less/SCSS 代码检查工具，
#             用于检查样式代码的规范和错误。
#
# 【字段具体含义 + 典型场景】
#
# 【基础配置】
#   extends  → 继承 stylelint-config-standard（标准规范）
#             + stylelint-config-prettier（不与 Prettier 冲突）
#   customSyntax → 使用 postcss-less 解析器（支持 Less 语法）
#
# 【规则配置】
#   no-descending-specificity    → 允许低特异性选择器在高性能选择器后面
#   no-duplicate-selectors       → 允许重复选择器（Less 嵌套可能产生）
#   font-family-no-missing-generic-family-keyword → 允许省略通用字体族
#   block-opening-brace-space-before → 大括号前必须有空格
#   declaration-trailing-semicolon → 不强制分号
#   declaration-colon-newline-after → 分号后不强制换行
#   indentation                 → 不强制缩进（由 Prettier 决定）
#   selector-class-pattern     → 不强制类名格式
#   keyframes-name-pattern    → 不强制动画名格式
#   no-invalid-position-at-import-rule → 允许 @import 在任何位置
#   number-max-precision        → 小数位数最多 6 位
#   color-function-notation    → 不强制颜色函数写法
#   selector-pseudo-class-no-unknown → 允许 :global 伪类（CSS Modules）

{
  "extends": ["stylelint-config-standard", "stylelint-config-prettier"],
  "customSyntax": "postcss-less",
  "rules": {
    "no-descending-specificity": null,
    "no-duplicate-selectors": null,
    "font-family-no-missing-generic-family-keyword": null,
    "block-opening-brace-space-before": "always",
    "declaration-trailing-semicolon": null,
    "declaration-colon-newline-after": null,
    "indentation": null,
    "selector-descendant-combinator-no-non-space": null,
    "selector-class-pattern": null,
    "keyframes-name-pattern": null,
    "no-invalid-position-at-import-rule": null,
    "number-max-precision": 6,
    "color-function-notation": null,
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": ["global"]
      }
    ]
  }
}
